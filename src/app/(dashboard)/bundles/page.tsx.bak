    monthlyCredits: 75000,
  },
  {
    id: "business_bundle",
    name: "Business Bundle",
    price: 900,
    currency: "MYR",
    period: "/month",
    description: "Full suite for multi-location chains: Agent Pro + Reservation Business",
    agentTier: "Agent Pro",
    reservationTier: "Business",
    features: [
      "Agent Pro: 3 WhatsApp #, 10 team, AI, analytics, 50K credits",
      "Reservation Business: Unlimited resources, 10 locations",
      "Multi-location staff management",
      "Advanced floor plans & event ticketing",
      "Stripe + SenangPay for both platforms",
      "100,000 combined credits/month",
      "Dedicated account manager",
      "Custom domain, white-label, full API",
