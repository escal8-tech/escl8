      <line x1="5" y1="12" x2="19" y2="12" />
    </svg>
  ),
  arrowRight: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  ),
};

export function BundlePricingPage() {
  const [selectedTier, setSelectedTier] = useState<string>("pro_bundle");
  const [billingCycle, setBillingCycle] = useState<"monthly" | "yearly">("monthly");

  return (
    <div className="min-h-screen bg-gray-50 py-16 px-4">
      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <div className="text-center mb-16">
          <div className="inline-flex items-center gap-2 bg-purple-50 text-purple-700 px-4 py-2 rounded-full text-sm font-medium mb-6">
            <Icons.package() />
            <span>Bundle Pricing</span>
          </div>

          <h1 className="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Better Together: Agent + Reservation
          </h1>
          <p className="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
            Combine our Agent chat automation with Reservation booking system
            and save up to 20% compared to individual plans.
          </p>

          {/* Billing Toggle */}
          <div className="inline-flex items-center p-1 bg-white rounded-lg shadow-sm border border-gray-200">
            {["monthly", "yearly"].map((cycle) => (
              <button
                key={cycle}
                onClick={() => setBillingCycle(cycle as "monthly" | "yearly")}
                className={cn(
                  "px-6 py-2 rounded-md text-sm font-medium transition-colors",
                  billingCycle === cycle
                    ? "bg-purple-600 text-white shadow-sm"
                    : "text-gray-600 hover:text-gray-900"
                )}
              >
                {cycle.charAt(0).toUpperCase() + cycle.slice(1)}
                {billingCycle === "yearly" && <span className="ml-2 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">Save 20%</span>}
              </button>
            ))}
          </div>

          {/* Savings Calculator */}
          <div className="mt-8 p-6 bg-green-50 rounded-xl border border-green-200 max-w-md mx-auto">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-green-700 font-medium">Annual Savings</p>
                <p className="text-3xl font-bold text-green-800">
                  {bundleTiers.find(t => t.id === "pro_bundle")?.savings * 12 + bundleTiers.find(t => t.id === "business_bundle")?.savings * 12} MYR/year
                </p>
              </div>
              <div className="bg-green-100 text-green-700 px-4 py-2 rounded-full text-sm font-medium">
                Up to 20% off
              </div>
            </div>
          </div>
        </div>

        {/* Tier Cards */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {bundleTiers.map((tier) => (
            <BundleCard
              key={tier.id}
              tier={tier}
              selected={selectedTier === tier.id}
              onSelect={() => setSelectedTier(tier.id)}
              billingCycle={billingCycle}
            />
          ))}
        </div>

        {/* What's Included Section */}
        <div className="mt-20">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
            What You Get in Every Bundle
          </h2>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            <IncludedCard
              icon={<Icons.messageSquare() />}
              title="Unified Communication"
              description="Single dashboard for WhatsApp chat automation and booking management"
            />
            <IncludedCard
              icon={<Icons.calendar() />}
              title="Seamless Booking Flow"
              description="Customers chat → book → pay → confirm all in one WhatsApp conversation"
            />
            <IncludedCard
              icon={<Icons.shield() />}
              title="Unified Billing"
              description="Single invoice, single payment, unified credit pool across both platforms"
            />
          </div>
        </div>

        {/* Savings Breakdown */}
        <div className="mt-16">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
            Bundle Savings Breakdown
          </h2>
          <SavingsBreakdown />
        </div>

        {/* FAQ */}
        <div className="mt-20">
          <h2 className="text-3xl font-bold text-center text-gray-900 mb-12">
            Bundle FAQs
          </h2>
          <BundleFAQSection />
        </div>
      </div>
    </div>
  );
}

function BundleCard({
  tier,
  selected,
  onSelect,
  billingCycle,
}: {
  tier: BundleTier;
  selected: boolean;
  onSelect: () => void;
  billingCycle: "monthly" | "yearly";
}) {
  const price = billingCycle === "yearly"
    ? Math.round(tier.price * 12 * 0.8)
    : tier.price;

  const individualPrice = tier.id === "starter_bundle" ? 400 :
                          tier.id === "pro_bundle" ? 750 :
                          tier.id === "business_bundle" ? 1400 : 2000;

  return (
    <div
      className={cn(
        "relative p-8 bg-white rounded-2xl shadow-sm border-2 transition-all duration-200",
        selected
          ? "border-purple-500 shadow-lg ring-2 ring-purple-500/20"
          : "border-gray-200 hover:border-gray-300"
      )}
      onClick={() => setSelectedTier(tier.id)}
    >
      {tier.popular && (
        <div className="absolute -top-3 left-1/2 -translate-x-1/2">
          <span className="bg-purple-600 text-white text-sm font-semibold px-4 py-1 rounded-full">
            Most Popular
          </span>
        </div>
      )}

      {tier.enterprise && (
        <div className="absolute -top-3 left-1/2 -translate-x-1/2">
          <span className="bg-gradient-to-r from-purple-600 to-pink-600 text-white text-sm font-semibold px-4 py-1 rounded-full">
            Enterprise
          </span>
        </div>
      )}

      {/* Savings Badge */}
      <div className="absolute -top-3 right-4">
        <span className="bg-green-100 text-green-700 text-sm font-semibold px-3 py-1 rounded-full">
          Save {tier.savings.toLocaleString()} MYR/mo
        </span>
      </div>

      <div className="mb-6">
        <div className="flex items-center gap-2 mb-2">
          <h3 className="text-xl font-bold text-gray-900">{tier.name}</h3>
          {tier.popular && <Icons.sparkles() />}
        </div>
        <p className="text-gray-600 text-sm mb-4">{tier.description}</p>

        <div className="mb-4 p-3 bg-purple-50 rounded-lg">
          <p className="text-sm text-purple-700">
            <strong>Includes:</strong> Agent <span className="font-medium">{tier.agentTier}</span> + Reservation <span className="font-medium">{tier.reservationTier}</span>
          </p>
        </div>

        <div className="mb-6">
          {tier.enterprise ? (
            <div className="text-center">
              <span className="text-4xl font-bold text-gray-900">Custom</span>
              <span className="text-gray-500 ml-1">/month</span>
            </div>
          ) : (
            <div className="flex items-baseline">
              <span className="text-4xl font-bold text-gray-900">{price.toLocaleString()}</span>
              <span className="text-gray-500 ml-1">/month</span>
            </div>
          )}
          {billingCycle === "yearly" && !tier.enterprise && (
            <p className="text-sm text-green-600 mt-1">
              Billed yearly: {Math.round((tier.price || 0) * 12 * 0.8).toLocaleString()} MYR/year
            </p>
          )}
        </div>

        {/* Individual vs Bundle Price */}
        {!tier.enterprise && (
          <div className="mb-4 p-3 bg-gray-50 rounded-lg text-center">
            <p className="text-sm text-gray-600">
              Individually: <span className="line-through text-gray-400">{individualPrice.toLocaleString()} MYR/mo</span>
            </p>
            <p className="text-sm text-green-600 font-semibold">
              Bundle: <span className="text-gray-900">{price.toLocaleString()} MYR/mo</span> (Save {tier.savings.toLocaleString()} MYR/mo)
            </p>
          </div>
        )}

      <ul className="space-y-3 mb-8">
        {tier.features.map((feature, index) => (
          <li key={index} className="flex items-start gap-3 text-gray-700">
            <Icons.check() />
            <span className="text-sm">{feature}</span>
          </li>
        ))}
      </ul>

      <button
        className={cn(
          "w-full py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200",
          tier.enterprise
            ? "bg-gradient-to-r from-purple-600 to-pink-600 text-white hover:from-purple-700 hover:to-pink-700"
            : "bg-purple-600 text-white hover:bg-purple-700"
        )}
        onClick={(e) => {
          e.stopPropagation();
          setSelectedTier(tier.id);
        }}
      >
        {tier.ctaText}
      </button>
    </div>
  );
}

function IncludedCard({ icon, title, description }: { icon: React.ReactNode; title: string; description: string }) {
  return (
    <div className="bg-white p-6 rounded-xl border border-gray-200 hover:border-purple-300 hover:shadow-lg transition-all">
      <div className="bg-purple-100 text-purple-600 p-3 rounded-lg w-fit mb-4">
        {icon}
      </div>
      <h3 className="text-lg font-semibold text-gray-900 mb-2">{title}</h3>
      <p className="text-gray-600 text-sm">{description}</p>
    </div>
  );
}

function SavingsBreakdown() {
  const savingsData = [
    { plan: "Starter Bundle", individual: "400", bundle: "350", save: "50" },
    { plan: "Pro Bundle", individual: "750", bundle: "550", save: "200" },
    { plan: "Business Bundle", individual: "1,400", bundle: "900", save: "500" },
  ];

  return (
    <div className="overflow-x-auto rounded-xl border border-gray-200 bg-white">
      <table className="w-full">
        <thead>
          <tr className="bg-purple-50 border-b border-gray-200">
            <th className="px-6 py-4 text-left text-sm font-semibold text-gray-900">Bundle Plan</th>
            <th className="px-6 py-4 text-center text-sm font-semibold text-gray-900">Individual Price</th>
            <th className="px-6 py-4 text-center text-sm font-semibold text-gray-900">Bundle Price</th>
            <th className="px-6 py-4 text-center text-sm font-semibold text-gray-900">Monthly Savings</th>
            <th className="px-6 py-4 text-center text-sm font-semibold text-gray-900">Annual Savings</th>
          </tr>
        </thead>
        <tbody className="divide-y divide-gray-100">
          {savingsData.map((item) => (
            <tr key={item.plan} className="hover:bg-gray-50">
              <td className="px-6 py-4 font-medium text-gray-900">{item.plan}</td>
              <td className="px-6 py-4 text-center text-gray-700">{item.individual} MYR</td>
              <td className="px-6 py-4 text-center text-purple-600 font-semibold">{item.bundle} MYR</td>
              <td className="px-6 py-4 text-center text-green-600 font-semibold">{item.save} MYR</td>
              <td className="px-6 py-4 text-center text-green-600 font-semibold">{(parseInt(item.save.replace(/,/g, "")) * 12).toLocaleString()} MYR</td>
            </tr>
          ))}
          <tr className="bg-green-50 font-bold">
            <td className="px-6 py-4 text-gray-900">Total Annual Savings (Pro + Business)</td>
            <td className="px-6 py-4 text-center"></td>
            <td className="px-6 py-4 text-center"></td>
            <td className="px-6 py-4 text-center text-green-600">700 MYR/mo</td>
            <td className="px-6 py-4 text-center text-green-600">8,400 MYR/year</td>
          </tr>
        </tbody>
      </table>
    </div>
  );
}

function BundleFAQSection() {
  const faqs = [
    {
      q: "Can I mix and match different tiers for Agent and Reservation?",
      a: "Currently we offer pre-configured bundles for the best value. Contact sales if you need a custom combination."
    },
    {
      q: "How does the shared credit pool work?",
      a: "Credits are shared across both Agent and Reservation platforms. AI messages in Agent and booking confirmations in Reservation both draw from the same pool."
    },
    {
      q: "Can I upgrade just one platform later?",
      a: "Yes, you can upgrade individual components. Just contact support and we'll adjust your bundle pricing accordingly."
    },
    {
      q: "What happens if one platform exceeds its credit limit?",
      a: "The shared pool is used first. If exhausted, you can purchase addon credits that apply to both platforms."
    },
    {
      q: "Do both platforms share the same WhatsApp number?",
      a: "Each platform can have its own WhatsApp Business number, or you can use the same number for both with our unified inbox."
    },
    {
      q: "Is there a minimum contract for bundles?",
      a: "No minimum contract. Monthly plans cancel anytime. Annual plans offer 20% discount with monthly billing option."
    },
  ];

  return (
    <div className="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, index) => (
        <details key={index} className="group bg-white border border-gray-200 rounded-xl overflow-hidden">
          <summary className="flex items-center justify-between p-6 cursor-pointer">
            <h3 className="text-lg font-semibold text-gray-900">{faq.q}</h3>
            <svg className="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div className="px-6 pb-6 text-gray-600">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  );
}

export default BundlePricingPage;