import { useState } from "react";
import { cn } from "@/lib/utils";

interface BundleTier {
  id: string;
  name: string;
  price: number;
  currency: string;
  period: string;
  description: string;
  agentTier: string;
  reservationTier: string;
  features: string[];
  highlighted: boolean;
  ctaText: string;
  popular?: boolean;
  enterprise?: boolean;
  savings: number;
  monthlyCredits: number;
}

