"use client";

import { useEffect, useState } from "react";
import { usePathname, useRouter, useSearchParams } from "next/navigation";
import { trpc } from "@/utils/trpc";
import { useToast } from "@/components/ToastProvider";
import { showSuccessToast, showErrorToast } from "@/components/toast-utils";

/* ─────────────────────────────────────────────────────────────────────────────
   ICONS (inline SVGs as component functions for clean dependency-free icons)
───────────────────────────────────────────────────────────────────────────── */
const Icons = {
  check: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <polyline points="20 6 9 17 4 12" />
    </svg>
  ),
  bell: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
      <path d="M13.73 21a2 2 0 0 1-3.46 0" />
    </svg>
  ),
  clock: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </svg>
  ),
  lock: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <rect x="3" y="11" width="18" height="10" rx="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
  ),
  settings: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="3" />
      <path d="M12 1 12 3" />
      <path d="M12 21 12 23" />
      <path d="M4.22 4.22 5.64 5.64" />
      <path d="M18.36 18.36 19.78 19.78" />
      <path d="M1 12 3 12" />
      <path d="M21 12 23 12" />
      <path d="M4.22 19.78 5.64 18.36" />
      <path d="M18.36 5.64 19.78 4.22" />
    </svg>
  ),
  calendar: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
      <line x1="16" y1="2" x2="16" y2="6" />
      <line x1="8" y1="2" x2="8" y2="6" />
      <line x1="3" y1="10" x2="21" y2="10" />
    </svg>
  ),
  zap: () => (
    <svg width="18" height="18" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
    </svg>
  ),
  crown: () => (
    <svg width="18" height="18" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <path d="M5 3h14c1.1 0 2 .9 2 2v14c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V5c0-1.1.9-2 2-2z" />
      <path d="M9 3V1M15 3V1" />
    </svg>
  ),
  shield: () => (
    <svg width="18" height="18" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </svg>
  ),
  user: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </svg>
  ),
  arrowRight: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  ),
  loading: () => (
    <svg width="24" height="24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" viewBox="0 0 24 24" className="animate-spin">
      <circle cx="12" cy="12" r="10" strokeOpacity="0.25" />
      <path d="M12 2a10 10 0 0 1 10 10" />
    </svg>
  ),
};

/* ─────────────────────────────────────────────────────────────────────────────
   TYPES
───────────────────────────────────────────────────────────────────────────── */
interface SubscriptionData {
  hasSubscription: boolean;
  status: string;
  planCode: string | null;
  planName: string | null;
  grantKind: string | null;
  subscriptionStatus: string | null;
  lastPaidAt: string | Date | null;
  nextDueAt: string | Date | null;
  monthlyCredits: number;
  creditsUsed: number;
  creditsBalance: number;
  priceAmount: number;
  currency: string;
  features: Record<string, any>;
  limits: Record<string, number | string | boolean | null>;
  isActive: boolean;
  isSpecialGrant: boolean;
}

const PLAN_DISPLAY_NAMES: Record<string, string> = {
  standard: "Standard",
  agent: "Agent Pro",
  pro_bundle: "Pro Bundle",
  enterprise: "Enterprise",
  RESERVE_BASIC: "Reserve Starter",
  RESERVE_PRO: "Reserve Professional",
  AGENT_BASIC: "Agent Basic",
  AGENT_GROWTH: "Agent Growth",
  AGENT_ENTERPRISE: "Agent Enterprise",
  BUNDLE_CORE: "Pro Bundle",
  BUNDLE_FULL: "Full Bundle",
  DEMO_FULL_ACCESS: "Demo Access",
  PARTNER_FULL_ACCESS: "Partner Access",
};

const STATUS_COLORS: Record<string, { bg: string; text: string }> = {
  active: { bg: "bg-emerald-500/20", text: "text-emerald-400" },
  past_due: { bg: "bg-amber-500/20", text: "text-amber-400" },
  pending_setup: { bg: "bg-blue-500/20", text: "text-blue-400" },
  cancelled: { bg: "bg-red-500/20", text: "text-red-400" },
  none: { bg: "bg-gray-500/20", text: "text-gray-400" },
};

const STATUS_LABELS: Record<string, string> = {
  active: "Active",
  past_due: "Past Due",
  pending_setup: "Pending Setup",
  cancelled: "Cancelled",
  none: "No Subscription",
};

const getStatusIcon = (status: string) => {
  switch (status) {
    case "active": return Icons.check();
    case "past_due": return Icons.bell();
    case "pending_setup": return Icons.clock();
    case "cancelled": return Icons.lock();
    default: return Icons.lock();
  }
};

const getPlanFeatures = (planCode: string | null): string[] => {
  if (!planCode) return [];
  const features: Record<string, string[]> = {
    standard: [
      "1 WhatsApp Business number",
      "Up to 3 team members",
      "10 concurrent conversations",
      "Basic message templates",
      "SenangPay integration",
      "10,000 credits/month",
      "Email support",
    ],
    agent: [
      "Up to 3 WhatsApp Business numbers",
      "Up to 10 team members",
      "100 concurrent conversations",
      "AI-powered responses with custom prompts",
      "Advanced analytics dashboard",
      "Webhook integrations",
      "50,000 credits/month",
      "Priority email support",
      "API access",
    ],
    pro_bundle: [
      "Everything in Agent Pro",
      "Full Reservation system access",
      "Unlimited resources & staff",
      "Floor plan management",
      "Events & ticketing",
      "Staff management & scheduling",
      "Stripe + SenangPay payments",
      "Custom domain & branding",
      "API access",
      "60,000 credits/month",
      "Priority support with dedicated manager",
    ],
    enterprise: [
      "Unlimited WhatsApp numbers",
      "Unlimited team members",
      "Unlimited concurrent conversations",
      "Custom AI model training",
      "Advanced analytics & reporting",
      "Custom webhook integrations",
      "White-label solution",
      "Dedicated account manager",
      "SLA guarantee",
      "On-premise deployment option",
      "Custom contract & billing",
      "Dedicated infrastructure",
    ],
  };
  return features[planCode] || [];
};

export default function AgentSubscriptionPage() {
  const pathname = usePathname();
  const router = useRouter();
  const searchParams = useSearchParams();
  const toast = useToast();
  const [subscription, setSubscription] = useState<SubscriptionData | null>(null);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);

  const subscriptionQuery = trpc.business.getSubscription.useQuery(undefined, {
    enabled: true,
    refetchOnWindowFocus: false,
  });

  useEffect(() => {
    if (subscriptionQuery.data) {
      setSubscription(subscriptionQuery.data as SubscriptionData);
    }
    setLoading(false);
  }, [subscriptionQuery.data]);

  const handleRefresh = async () => {
    setRefreshing(true);
    await subscriptionQuery.refetch();
    setRefreshing(false);
    showSuccessToast(toast, "Refreshed", "Subscription data updated");
  };

  const handleManagePlan = (planCode: string) => {
    if (!subscription?.planCode) return;
    router.push(`/api/billing/recurring-checkout?planCode=${planCode}`);
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-[var(--bg-canvas)] flex items-center justify-center">
        <Icons.loading() />
      </div>
    );
  }

  if (!subscription) {
    return (
      <div className="min-h-screen bg-[var(--bg-canvas)] flex items-center justify-center">
        <p className="text-[var(--text-secondary)]">Unable to load subscription data</p>
      </div>
    );
  }

  const statusConfig = STATUS_COLORS[subscription.status] || STATUS_COLORS.none;
  const StatusIcon = getStatusIcon(subscription.status);
  const isActive = subscription.isActive;

  const formatCurrency = (amount: number, currency: string) => {
    return new Intl.NumberFormat("en-MY", {
      style: "currency",
      currency,
      minimumFractionDigits: 0,
    }).format(amount);
  };

  const formatDate = (date: string | Date | null) => {
    if (!date) return "N/A";
    try {
      const d = new Date(date);
      return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
    } catch {
      return "Invalid date";
    }
  };

  return (
    <div className="min-h-screen bg-[var(--bg-canvas)]">
      <div className="max-w-7xl mx-auto px-4 py-8">
        {/* Header */}
        <div className="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
          <div>
            <p className="text-xs font-semibold uppercase tracking-[0.08em] text-[var(--text-tertiary)] mb-1">
              Escal8 WhatsApp Agent
            </p>
            <h1 className="text-3xl font-bold text-white font-heading">
              Subscription & Billing
            </h1>
            <p className="text-[var(--text-secondary)] mt-1">
              Manage your WhatsApp Agent subscription, view credits, and billing details
            </p>
          </div>
          <div className="flex items-center gap-3">
            <button
              onClick={handleRefresh}
              disabled={refreshing}
              className="flex items-center gap-2 px-4 py-2 bg-[var(--bg-surface-elevated)] border border-white/6 rounded-lg text-sm font-medium text-[var(--text-secondary)] hover:text-white hover:bg-white/5 transition-all disabled:opacity-50"
            >
              <Icons.loading() />
              Refresh
            </button>
          </div>
        </div>

        {/* Current Subscription Card */}
        <div className={`rounded-2xl border-2 p-6 transition-all ${
          isActive ? "border-emerald-500/30 bg-emerald-500/5" : "border-white/6 bg-[var(--bg-surface-elevated)]"
        }`}>
          <div className="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
            <div className="flex items-center gap-4">
              <div className={`flex items-center justify-center w-16 h-16 rounded-2xl ${statusConfig.bg}`}>
                {StatusIcon}
              </div>
              <div>
                <div className="flex items-center gap-3">
                  <h2 className="text-2xl font-bold text-white font-heading">
                    {subscription.planName ? PLAN_DISPLAY_NAMES[subscription.planName] || subscription.planName : "No Active Plan"}
                  </h2>
                  <span className={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${statusConfig.bg} ${statusConfig.text}`}>
                    {STATUS_LABELS[subscription.status] || subscription.status}
                  </span>
                  {subscription.isSpecialGrant && (
                    <span className="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-500/20 text-purple-400">
                      {subscription.grantKind === "demo" ? "Demo Access" : "Partner Access"}
                    </span>
                  )}
                </div>
                <p className="text-[var(--text-secondary)] mt-1">
                  Plan: <span className="font-medium text-white">{subscription.planCode || "N/A"}</span>
                  {subscription.priceAmount > 0 && (
                    <> • {formatCurrency(subscription.priceAmount, subscription.currency)}/{subscription.currency === "MYR" ? "month" : "month"}</>
                  )}
                </p>
              </div>
            </div>

            <div className="flex flex-wrap items-center gap-4">
              {/* Next Billing Date */}
              <div className="flex items-center gap-3 p-4 bg-white/5 rounded-xl border border-white/6 min-w-[200px]">
                <div className="flex items-center justify-center w-10 h-10 bg-emerald-500/20 rounded-lg">
                  <Icons.calendar() />
                </div>
                <div>
                  <p className="text-xs font-semibold uppercase tracking-[0.05em] text-[var(--text-tertiary)]">Next Payment</p>
                  <p className="text-lg font-bold text-white">
                    {subscription.nextDueAt ? formatDate(subscription.nextDueAt) : "N/A"}
                  </p>
                </div>
              </div>

              {/* Monthly Credits */}
              <div className="flex items-center gap-3 p-4 bg-white/5 rounded-xl border border-white/6 min-w-[200px]">
                <div className="flex items-center justify-center w-10 h-10 bg-blue-500/20 rounded-lg">
                  <Icons.zap() />
                </div>
                <div>
                  <p className="text-xs font-semibold uppercase tracking-[0.05em] text-[var(--text-tertiary)]">Monthly Credits</p>
                  <div className="flex items-baseline gap-2">
                    <span className="text-2xl font-bold text-white">
                      {subscription.monthlyCredits.toLocaleString()}
                    </span>
                    <span className="text-[var(--text-tertiary)]">/month</span>
                  </div>
                </div>
              </div>

              {/* Credits Usage */}
              {subscription.monthlyCredits > 0 && (
                <div className="flex items-center gap-3 p-4 bg-white/5 rounded-xl border border-white/6 min-w-[200px]">
                  <div className="flex items-center justify-center w-10 h-10 bg-purple-500/20 rounded-lg">
                    <Icons.crown() />
                  </div>
                  <div>
                    <p className="text-xs font-semibold uppercase tracking-[0.05em] text-[var(--text-tertiary)]">Credits Used</p>
                    <div className="flex items-baseline gap-2">
                      <span className="text-2xl font-bold text-white">
                        {subscription.creditsUsed.toLocaleString()}
                      </span>
                      <span className="text-[var(--text-tertiary)]">
                        / {subscription.monthlyCredits.toLocaleString()}
                      </span>
                    </div>
                    <div className="mt-1 h-2 bg-white/10 rounded-full overflow-hidden w-32">
                      <div
                        className="h-full bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full transition-all duration-500"
                        style={{
                          width: `${subscription.monthlyCredits > 0
                            ? Math.min(100, (subscription.creditsUsed / subscription.monthlyCredits) * 100)
                            : 0}%`,
                        }}
                      />
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>

          {/* Manage Plan Button */}
          {isActive && subscription.planCode && (
            <div className="mt-6 pt-6 border-t border-white/6">
              <button
                onClick={() => handleManagePlan(subscription.planCode!)}
                className="w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[var(--accent-gold)] text-[var(--brand-blue-deep)] rounded-xl font-semibold hover:bg-[var(--accent-gold-soft)] transition-colors"
              >
                <Icons.settings() />
                Manage Plan / Upgrade
              </button>
            </div>
          )}

          {!isActive && (
            <div className="mt-6 pt-6 border-t border-white/6">
              <div className="flex items-center gap-3 p-4 bg-amber-500/10 border border-amber-500/30 rounded-xl">
                <Icons.bell() />
                <div className="text-sm text-white">
                  <p className="font-medium">No active subscription</p>
                  <p className="mt-1 text-[var(--text-secondary)]">Your WhatsApp Agent platform requires an active subscription to access all features.</p>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Subscription Details Grid */}
        <div className="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Plan Features */}
          <div className="lg:col-span-2 bg-[var(--bg-surface-elevated)] rounded-2xl border border-white/6 overflow-hidden">
            <div className="p-5 border-b border-white/6">
              <h3 className="text-lg font-semibold text-white flex items-center gap-2 font-heading">
                <Icons.shield() />
                Plan Features
              </h3>
            </div>
            <div className="p-5">
              {subscription.hasSubscription ? (
                <div className="space-y-3">
                  {getPlanFeatures(subscription.planCode || "").map((feature, index) => (
                    <div key={index} className="flex items-center gap-3 text-[var(--text-secondary)]">
                      <Icons.check() />
                      <span className="text-sm">{feature}</span>
                    </div>
                  ))}
                  {getPlanFeatures(subscription.planCode || "").length === 0 && (
                    <p className="text-[var(--text-tertiary)] text-sm">No feature details available for this plan.</p>
                  )}
                </div>
              ) : (
                <div className="text-center py-8">
                  <Icons.lock() />
                  <p className="text-[var(--text-secondary)] mt-4">No active subscription to display features.</p>
                  <p className="text-sm text-[var(--text-tertiary)] mt-1">Upgrade to unlock WhatsApp Agent platform features.</p>
                </div>
              )}
            </div>
          </div>

          {/* Limits & Usage */}
          <div className="bg-[var(--bg-surface-elevated)] rounded-2xl border border-white/6 overflow-hidden">
            <div className="p-5 border-b border-white/6">
              <h3 className="text-lg font-semibold text-white flex items-center gap-2 font-heading">
                <Icons.user() />
                Limits & Usage
              </h3>
            </div>
            <div className="p-5 space-y-5">
              {Object.entries(subscription.limits).length > 0 ? (
                Object.entries(subscription.limits).map(([key, value]) => {
                  const label = key
                    .replace("agent.", "")
                    .replace(/\./g, " ")
                    .replace(/\b\w/g, (l) => l.toUpperCase());
                  return (
                    <div key={key} className="space-y-1">
                      <div className="flex justify-between text-sm">
                        <span className="text-[var(--text-secondary)]">{label}</span>
                        <span className="font-medium text-white">
                          {value === "unlimited" || value === true || (typeof value === "number" && value > 999) ? "Unlimited" : value}
                        </span>
                      </div>
                      <div className="h-2 bg-white/10 rounded-full overflow-hidden">
                        <div className="h-full bg-[var(--accent-gold)] rounded-full" style={{ width: "60%" }} />
                      </div>
                    </div>
                  );
                })
              ) : (
                <p className="text-[var(--text-tertiary)] text-sm text-center py-4">
                  No specific limits configured for this plan.
                </p>
              )}

              {/* Credits Detail */}
              <div className="pt-4 border-t border-white/6">
                <h4 className="font-medium text-white mb-3">Credits Breakdown</h4>
                <div className="space-y-2 text-sm">
                  <div className="flex justify-between">
                    <span className="text-[var(--text-secondary)]">Monthly Allocation</span>
                    <span className="font-medium text-white">{subscription.monthlyCredits.toLocaleString()}</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-[var(--text-secondary)]">Used This Period</span>
                    <span className="font-medium text-white">{subscription.creditsUsed.toLocaleString()}</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-[var(--text-secondary)]">Remaining Balance</span>
                    <span className="font-medium text-emerald-400">{subscription.creditsBalance.toLocaleString()}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Billing History Placeholder */}
        <div className="mt-8 bg-[var(--bg-surface-elevated)] rounded-2xl border border-white/6 overflow-hidden">
          <div className="p-5 border-b border-white/6 flex items-center justify-between">
            <h3 className="text-lg font-semibold text-white flex items-center gap-2 font-heading">
              <Icons.calendar() />
              Billing History
            </h3>
            <button className="text-sm text-[var(--accent-gold)] hover:underline flex items-center gap-1">
              View All <Icons.arrowRight() />
            </button>
          </div>
          <div className="p-5">
            <div className="text-center py-8">
              <Icons.lock() />
              <p className="text-[var(--text-secondary)] mt-4">Billing history will appear here after your first payment.</p>
              <p className="text-sm text-[var(--text-tertiary)] mt-1">Payments are processed via SenangPay recurring billing.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}